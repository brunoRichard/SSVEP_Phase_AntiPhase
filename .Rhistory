residuals <- array(NA, dim = dim(SNRAll))
for (i in 1:dim(SNRAll)[3]){
residuals[,,i] <- SNRAll[,,i] - theHData
}
plot(SNRAll, residuals)
abline(h = 0)
install.packages("lmtest")
plot(SNRAll, residuals)
abline(h = 0)
length(residuals)
c(SNRAll)
plot(c(SNRAll), c(residuals))
n <- length(residuals)
sq_residuals <- residuals^2
aux_model <- lm(c(sq_residuals) ~ c(SNRAll))
aux_model
r_sq <- summary(aux_model)$r.squared
lm_stat <- n * r_sq
lm_stat
p_val <- 1 - pchisq(lm_stat, df = 1)
p_val
pchisq(lm_stat, df = 1)
lm_stat
cor.test(abs(c(residuals)), c(SNRAll), method = "spearman")
cor(abs(c(residuals)), c(SNRAll), method = "spearman")
abs(c(residuals))
c(SNRAll)
